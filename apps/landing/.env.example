# Copy this file to .env and fill in your URLs for local development.
# All variables MUST be prefixed with VITE_ to be exposed to the client.

# Where the deployed Storybook lives. Set this once the Firebase storybook
# site is live so the landing page links into it.
VITE_STORYBOOK_URL=http://localhost:6006

# Public GitHub repo URL for navbar / footer links.
VITE_GITHUB_URL=https://github.com/headlessButSmart/fillament
