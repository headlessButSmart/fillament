{
  "name": "@fillament/core",
  "version": "0.3.0",
  "description": "Framework-agnostic form engine for Fillament — state, field registry, validation orchestration, subscriptions.",
  "license": "MIT",
  "author": "headlessButSmart",
  "homepage": "https://github.com/headlessButSmart/fillament/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/headlessButSmart/fillament.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/headlessButSmart/fillament/issues"
  },
  "keywords": [
    "fillament",
    "form",
    "forms",
    "validation",
    "typescript",
    "state-management",
    "field"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
