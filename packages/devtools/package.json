{
  "name": "@fillament/devtools",
  "version": "0.1.0",
  "description": "Free in-app DevTools panel for Fillament — inspect values, fields, errors, validation timing, render counts.",
  "license": "MIT",
  "author": "headlessButSmart",
  "homepage": "https://github.com/headlessButSmart/fillament/tree/main/packages/devtools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/headlessButSmart/fillament.git",
    "directory": "packages/devtools"
  },
  "bugs": {
    "url": "https://github.com/headlessButSmart/fillament/issues"
  },
  "keywords": ["fillament", "devtools", "react", "form", "inspector", "debugging"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@fillament/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
