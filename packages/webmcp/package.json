{
  "name": "@fillament/webmcp",
  "version": "1.0.0",
  "description": "Expose Fillament forms as WebMCP tools so in-browser AI agents can read, fill, and (optionally) submit them — derived from the form's validation schema. Targets the W3C Web Model Context API with an @mcp-b/transports bridge for today's browsers.",
  "license": "MIT",
  "author": "headlessButSmart",
  "homepage": "https://github.com/headlessButSmart/fillament/tree/main/packages/webmcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/headlessButSmart/fillament.git",
    "directory": "packages/webmcp"
  },
  "bugs": {
    "url": "https://github.com/headlessButSmart/fillament/issues"
  },
  "keywords": [
    "fillament",
    "form",
    "webmcp",
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "browser"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mcp-b": {
      "types": "./dist/mcp-b.d.ts",
      "import": "./dist/mcp-b.js",
      "require": "./dist/mcp-b.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@fillament/core": "workspace:*",
    "@mcp-b/transports": ">=0.1.0",
    "@modelcontextprotocol/sdk": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@mcp-b/transports": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "@fillament/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
