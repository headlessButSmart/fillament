{
  "name": "@fillament/zod",
  "version": "0.2.0",
  "description": "Zod validation adapter for Fillament.",
  "license": "MIT",
  "author": "headlessButSmart",
  "homepage": "https://github.com/headlessButSmart/fillament/tree/main/packages/zod#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/headlessButSmart/fillament.git",
    "directory": "packages/zod"
  },
  "bugs": {
    "url": "https://github.com/headlessButSmart/fillament/issues"
  },
  "keywords": [
    "fillament",
    "zod",
    "validation",
    "form",
    "adapter",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "dependencies": {
    "@fillament/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "zod": "^3.22.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
