{
  "name": "@fillament/blueprints",
  "version": "2.0.0",
  "description": "Starter form blueprints for Fillament — login, signup, contact, surveys, commerce, and onboarding flows.",
  "license": "MIT",
  "author": "headlessButSmart",
  "homepage": "https://github.com/headlessButSmart/fillament/tree/main/packages/blueprints#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/headlessButSmart/fillament.git",
    "directory": "packages/blueprints"
  },
  "bugs": {
    "url": "https://github.com/headlessButSmart/fillament/issues"
  },
  "keywords": [
    "fillament",
    "form",
    "blueprints",
    "starter",
    "templates"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "require": "./dist/auth.cjs"
    },
    "./contact": {
      "types": "./dist/contact.d.ts",
      "import": "./dist/contact.js",
      "require": "./dist/contact.cjs"
    },
    "./survey": {
      "types": "./dist/survey.d.ts",
      "import": "./dist/survey.js",
      "require": "./dist/survey.cjs"
    },
    "./commerce": {
      "types": "./dist/commerce.d.ts",
      "import": "./dist/commerce.js",
      "require": "./dist/commerce.cjs"
    },
    "./onboarding": {
      "types": "./dist/onboarding.d.ts",
      "import": "./dist/onboarding.js",
      "require": "./dist/onboarding.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@fillament/core": "workspace:*"
  },
  "dependencies": {
    "@fillament/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
